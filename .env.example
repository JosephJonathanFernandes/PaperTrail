# PaperTrail Environment Configuration

# Required: Your Chrome Extension ID (needed for Flask-CORS to accept requests)
CHROME_EXTENSION_ID=your_extension_id_here

# Required: Email address for Unpaywall API rate limiting
UNPAYWALL_EMAIL=your_email@example.com

# Optional: Minimum score for web search fallbacks (Default: 50)
MIN_SCORE_THRESHOLD=50

# Optional: API Rate Limiting (Default: 10 per minute)
API_RATE_LIMIT=10/minute

# Optional: Enable Flask Debug Mode
FLASK_DEBUG=False
